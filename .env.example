# ── Reddit API ────────────────────────────────────────────────────────────────
# Get these from https://www.reddit.com/prefs/apps — create a "script" app
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PickledEggsCo/1.0

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by all agents
# Defaults to claude-sonnet-4-6
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Shopify Admin API ─────────────────────────────────────────────────────────
# Shop domain (no https://, no trailing slash)
SHOPIFY_SHOP_DOMAIN=pickledeggsco.myshopify.com
# Create an Admin API access token in Shopify Partners → Apps → your private app
SHOPIFY_ACCESS_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use local SQLite at data/pickled_eggs.db
# On Railway, this is set automatically when you provision a Postgres plugin
DATABASE_URL=

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_PORT=5050

# ── Tuning ────────────────────────────────────────────────────────────────────
# Minimum Claude relevance score (0-10) for listener posts to enter the queue
MIN_RELEVANCE_SCORE=6
